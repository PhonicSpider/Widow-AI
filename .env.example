# Copy this file to .env and fill in your keys.

# -- Anthropic ---------------------------------------------------
ANTHROPIC_API_KEY=

# -- Provider selection ------------------------------------------
# anthropic | gemini | ollama | deepseek
WIDOW_PROVIDER=anthropic

# Model override -- leave blank to use each provider's default
# Defaults: anthropic=claude-sonnet-4-6, gemini=gemini-2.5-flash,
#           ollama=llama3.1:70b, deepseek=deepseek-chat
WIDOW_MODEL=

# -- Gemini (free tier) ------------------------------------------
# Get key free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# -- Ollama (local, no key needed) -------------------------------
OLLAMA_URL=http://localhost:11434/v1

# -- DeepSeek ----------------------------------------------------
DEEPSEEK_API_KEY=
DEEPSEEK_URL=https://api.deepseek.com/v1

# -- Sub-agent provider (research + writing agents) --------------
# Override which model handles research/writing delegations.
# WIDOW_SUBAGENT_PROVIDER: anthropic | gemini  (default: same as WIDOW_PROVIDER)
# WIDOW_SUBAGENT_MODEL: model name override     (anthropic default: claude-haiku-4-5-20251001, gemini default: gemini-2.5-flash)
WIDOW_SUBAGENT_PROVIDER=
WIDOW_SUBAGENT_MODEL=

# -- Brave Search (web search for research agent) ----------------
# Free tier: 2,000 queries/month — https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# -- Hugging Face (image generation) ----------------------------
# Free account at https://huggingface.co — Settings > Access Tokens
HF_API_KEY=

# -- GitHub ------------------------------------------------------
# Personal access token — needed for private repos and creating issues/PRs
# Create at https://github.com/settings/tokens (repo scope for private repos)
GITHUB_TOKEN=

# -- Discord -----------------------------------------------------
# Create a bot at https://discord.com/developers/applications
# Add to your server with bot + message read/write permissions
DISCORD_BOT_TOKEN=

# -- OBS WebSocket -----------------------------------------------
# Enable: OBS → Tools → WebSocket Server Settings → Enable
OBS_WS_URL=ws://localhost:4455
OBS_WS_PASSWORD=

# -- YouTube Data API v3 -----------------------------------------
# Enable at https://console.cloud.google.com → APIs → YouTube Data API v3
# Free tier: 10,000 quota units/day (search = 100 units, reads = 1 unit)
YOUTUBE_API_KEY=

# -- Email (SMTP send) -------------------------------------------
# Gmail: enable 2FA → myaccount.google.com → Security → App Passwords → generate one
#   SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=you@gmail.com, SMTP_PASS=<app-password>
# Outlook: SMTP_HOST=smtp.office365.com, SMTP_PORT=587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# -- Email (IMAP read/manage) ------------------------------------
# Same app password as SMTP. Port 993 with TLS is the standard.
# Gmail: IMAP_HOST=imap.gmail.com  IMAP_PORT=993  IMAP_USER=you@gmail.com
# Outlook: IMAP_HOST=outlook.office365.com  IMAP_PORT=993
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
IMAP_TLS=true
IMAP_NAME=personal

# Second IMAP account — add SMTP_HOST_2 etc. for sending from it too
# Use _3, _4 etc. for additional accounts
IMAP_HOST_2=
IMAP_PORT_2=993
IMAP_USER_2=
IMAP_PASS_2=
IMAP_TLS_2=true
IMAP_NAME_2=work

# Second SMTP account
SMTP_HOST_2=
SMTP_PORT_2=587
SMTP_USER_2=
SMTP_PASS_2=
SMTP_FROM_2=
SMTP_NAME_2=work

# -- Chatterbox TTS ----------------------------------------------
# See README for server setup. Voice cloning: drop widow.wav in voices/.
CHATTERBOX_DIR=D:\Chatterbox-TTS-Server
CHATTERBOX_URL=http://localhost:8004
CHATTERBOX_VOICE=widow.wav
# Voice quality (all optional -- server defaults are used if omitted)
CHATTERBOX_EXAGGERATION=0.35   # 0.0-1.0, lower = calmer/flatter, higher = more expressive
CHATTERBOX_CFG_WEIGHT=0.6      # 0.0-1.0, higher = closer to reference voice
CHATTERBOX_TEMPERATURE=0.75    # 0.0-1.0, higher = more varied delivery
CHATTERBOX_SPEED=1.0           # speech rate multiplier
